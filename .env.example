# Copy this file to .env.local for local development
# In Vercel, set these as environment variables in the dashboard

# Vercel Postgres (auto-injected when you connect a Postgres DB in Vercel)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Auth — generate a long random string (e.g. `openssl rand -base64 32`)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Site
NEXT_PUBLIC_SITE_URL=https://rithalaupdate.online
NEXT_PUBLIC_SITE_NAME=Rithala Update

# Initial admin (used by db:setup script)
ADMIN_EMAIL=rithalyarajput@gmail.com
ADMIN_PASSWORD=changeme123

# Optional: Vercel Blob for image uploads
BLOB_READ_WRITE_TOKEN=
